    "test:unit": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@swiftpms/tsconfig": "workspace:*",
    "@swiftpms/eslint-config": "workspace:*",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
