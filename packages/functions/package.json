{
  "name": "@swiftpms/functions",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests --exclude 'src/__tests__/**'",
    "test:unit": "vitest run --passWithNoTests --exclude 'src/__tests__/**'",
    "test:rules": "firebase emulators:exec --only firestore 'vitest run src/__tests__'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@swiftpms/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^7.0.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@swiftpms/tsconfig": "workspace:*",
    "@firebase/rules-unit-testing": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "eslint": "^9.0.0",
    "firebase-functions-test": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": "22"
  }
}
