      "//": "Payment-attempt history on the folio page — orders every intent for a reservation newest-first.",
      "collectionGroup": "paymentIntents",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "reservationId", "order": "ASCENDING" },
        { "fieldPath": "initiatedAt", "order": "DESCENDING" }
