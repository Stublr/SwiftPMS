rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function belongsToTenant(tenantId) {
      return isAuthenticated() && request.auth.token.tenantId == tenantId;
    }

    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole('super_admin');
    }

    function isManager() {
      return hasRole('property_manager') || isAdmin();
    }

    function isStaff() {
      return hasRole('super_admin')
          || hasRole('property_manager')
          || hasRole('front_desk')
          || hasRole('housekeeping')
          || hasRole('auditor');
    }

    function isGuest() {
      return hasRole('guest');
    }

    function tenantStaff(tenantId) {
      return belongsToTenant(tenantId) && isStaff();
    }

    function ownsGuestDoc(guestId) {
      // createGuestAccount uses Firebase Auth UID as the guest doc ID.
      return isAuthenticated() && request.auth.uid == guestId;
    }

    function isOwnReservation() {
      return isAuthenticated()
          && resource != null
          && resource.data.guestId == request.auth.uid;
    }

    function hasPropertyAccess(propertyId) {
      return isAuthenticated()
          && request.auth.token.propertyIds != null
          && request.auth.token.propertyIds.hasAny([propertyId]);
    }

    // Tenant root
    match /tenants/{tenantId} {
      allow read: if belongsToTenant(tenantId);
      allow write: if belongsToTenant(tenantId) && isAdmin();

      // Users — staff can read each other for assignment UI; only admins can write
      match /users/{userId} {
        allow read: if tenantStaff(tenantId);
        allow write: if belongsToTenant(tenantId) && isAdmin();
      }

      // Guests — staff CRUD; guests read only their own doc
      match /guests/{guestId} {
        allow read: if tenantStaff(tenantId) || ownsGuestDoc(guestId);
        allow create, update: if tenantStaff(tenantId);
        allow delete: if belongsToTenant(tenantId) && isManager();
      }

      // Room Types — publicly readable (booking inventory is non-sensitive
      // and the guest portal must list it before login). Manager+ writes.
      match /roomTypes/{roomTypeId} {
        allow read: if true;
        allow write: if belongsToTenant(tenantId) && isManager();
      }

      // Audit log — Cloud Functions write, managers read
      match /auditLog/{logId} {
        allow read: if belongsToTenant(tenantId) && isManager();
        allow write: if false;
      }

      // Properties — publicly readable (the guest portal must list lodges
      // before login). Address + amenities are non-sensitive. Admin writes.
      match /properties/{propertyId} {
        allow read: if true;
        allow write: if belongsToTenant(tenantId) && isAdmin();

        // Rooms — public read (capacity / status not sensitive; the guest
        // portal's checkAvailability also reads them). Staff with access write.
        match /rooms/{roomId} {
          allow read: if true;
          allow create, update: if belongsToTenant(tenantId)
                                  && (isAdmin()
                                      || (isStaff() && hasPropertyAccess(propertyId)));
          allow delete: if belongsToTenant(tenantId) && isManager();
        }

        // Reservations — staff read all; guests read only their own.
        // Mutations are Cloud Functions only (rules deny direct writes).
        match /reservations/{reservationId} {
          allow read: if tenantStaff(tenantId) || isOwnReservation();
          allow write: if false;
        }

        // Folios — staff read all; guests read only the folio for their
        // own reservation (folio.guestId carries the same UID).
        match /folios/{folioId} {
          allow read: if tenantStaff(tenantId) || isOwnReservation();
          allow write: if false;
        }

        // Daily aggregates — staff (auditor+) only. Not public.
        match /dailyAggregates/{date} {
          allow read: if tenantStaff(tenantId);
          allow write: if false;
        }

        // Cash-up shifts — staff read all in-tenant; Cloud Functions write
        // (openShift + closeShift enforce the "one open at a time" rule).
        match /shifts/{shiftId} {
          allow read: if tenantStaff(tenantId);
          allow write: if false;
        }

        // Payment intents — staff read all; the initiating user reads their own
        // (initiatedBy carries the auth UID). Cloud Functions write.
        match /paymentIntents/{paymentIntentId} {
          allow read: if tenantStaff(tenantId)
                       || (isAuthenticated()
                           && resource != null
                           && resource.data.initiatedBy == request.auth.uid);
          allow write: if false;
        }
      }
    }
  }
}
